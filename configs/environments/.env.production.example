# Environment Configuration Template — Production
# ALL secrets must come from Secret Manager (AWS Secrets Manager / HashiCorp Vault)
# This file is a TEMPLATE ONLY — no real values should ever be placed here

# ─── Application ──────────────────────────────────────────
APP_ENV=production
APP_PORT=3001
APP_VERSION=REPLACE_WITH_RELEASE_VERSION
APP_NAME=ERP7

# ─── Frontend (Next.js) ───────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.erp7.yourdomain.com/api/v1
NEXT_PUBLIC_APP_VERSION=REPLACE_WITH_RELEASE_VERSION

# ─── Database ─────────────────────────────────────────────
# Retrieved from Secret Manager at runtime
DATABASE_HOST=SECRET_MANAGER:database/host
DATABASE_PORT=5432
DATABASE_NAME=erp7_production
DATABASE_USER=SECRET_MANAGER:database/user
DATABASE_PASSWORD=SECRET_MANAGER:database/password
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=50
DATABASE_SSL=true

# ─── Redis ────────────────────────────────────────────────
REDIS_HOST=SECRET_MANAGER:redis/host
REDIS_PORT=6379
REDIS_PASSWORD=SECRET_MANAGER:redis/password

# ─── Authentication ───────────────────────────────────────
# MUST be retrieved from Secret Manager — NEVER hardcoded
JWT_ACCESS_SECRET=SECRET_MANAGER:auth/jwt-access-secret
JWT_ACCESS_EXPIRY_SECONDS=900
JWT_REFRESH_SECRET=SECRET_MANAGER:auth/jwt-refresh-secret
JWT_REFRESH_EXPIRY_DAYS=7

# ─── Email ────────────────────────────────────────────────
EMAIL_SMTP_HOST=SECRET_MANAGER:email/smtp-host
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=SECRET_MANAGER:email/smtp-user
EMAIL_SMTP_PASSWORD=SECRET_MANAGER:email/smtp-password
EMAIL_FROM_ADDRESS=noreply@erp7.yourdomain.com

# ─── Feature Flags ────────────────────────────────────────
FEATURE_FLAG_ADVANCED_ANALYTICS=false
FEATURE_FLAG_MANUFACTURING_MODULE=true
FEATURE_FLAG_MULTI_CURRENCY=false
FEATURE_FLAG_AI_FORECASTING=false

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ─── File Storage ─────────────────────────────────────────
STORAGE_PROVIDER=s3
STORAGE_S3_BUCKET=SECRET_MANAGER:storage/s3-bucket
STORAGE_S3_REGION=ap-south-1
STORAGE_S3_ACCESS_KEY=SECRET_MANAGER:storage/s3-access-key
STORAGE_S3_SECRET_KEY=SECRET_MANAGER:storage/s3-secret-key

# ─── CORS ─────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://erp7.yourdomain.com

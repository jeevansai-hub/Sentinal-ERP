# Environment Configuration Template — Development
# Copy this file to apps/api/.env and apps/web/.env.local
# NEVER commit actual .env files to version control

# ─── Application ──────────────────────────────────────────
APP_ENV=development
APP_PORT=3001
APP_VERSION=0.1.0
APP_NAME=ERP7

# ─── Frontend (Next.js) ───────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_VERSION=0.1.0

# ─── Database ─────────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=erp7_development
DATABASE_USER=erp7_dev
DATABASE_PASSWORD=REPLACE_WITH_LOCAL_PASSWORD
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# ─── Redis ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Authentication ───────────────────────────────────────
# DO NOT use these values in staging/production
# Use Secret Manager for production secrets
JWT_ACCESS_SECRET=REPLACE_WITH_LOCAL_SECRET_MIN_32_CHARS
JWT_ACCESS_EXPIRY_SECONDS=900
JWT_REFRESH_SECRET=REPLACE_WITH_LOCAL_REFRESH_SECRET_MIN_32_CHARS
JWT_REFRESH_EXPIRY_DAYS=7

# ─── Email (use Mailtrap or similar for dev) ──────────────
EMAIL_SMTP_HOST=smtp.mailtrap.io
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=REPLACE_WITH_DEV_SMTP_USER
EMAIL_SMTP_PASSWORD=REPLACE_WITH_DEV_SMTP_PASSWORD
EMAIL_FROM_ADDRESS=noreply@erp7.local

# ─── Feature Flags ────────────────────────────────────────
FEATURE_FLAG_ADVANCED_ANALYTICS=false
FEATURE_FLAG_MANUFACTURING_MODULE=true
FEATURE_FLAG_MULTI_CURRENCY=false
FEATURE_FLAG_AI_FORECASTING=false

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=pretty

# ─── File Storage (use local disk for dev) ────────────────
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads

# ─── CORS ─────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

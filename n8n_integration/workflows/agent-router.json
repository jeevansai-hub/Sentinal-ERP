      ]
    },
    {
      "parameters": {
        "workflowId": "flow-knowledge",
        "options": {
          "waitForCompletion": true
        }
      },
      "id": "node-exec-knowledge-flow",
      "name": "Execute Knowledge Flow",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        800,
        600
      ]
    }
  ],
  "connections": {

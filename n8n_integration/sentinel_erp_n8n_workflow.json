    {
      "parameters": {
        "jsCode": "let rawText = item.json.body.message || item.json.body.request_message || '';\nlet isViolated = false;\nlet violations = [];\n\nconst ccPattern = /\\b(?:4[0-9]{12}(?:[0-9]{3})?|5[1-5][0-9]{14}|3[47][0-9]{13})\\b/;\nconst ssnPattern = /\\b\\d{3}-\\d{2}-\\d{4}\\b/;\n\nif (ccPattern.test(rawText)) {\n  rawText = rawText.replace(ccPattern, '[MASKED_PII_CC]');\n  violations.push('Credit Card leak scrubbed');\n}\nif (ssnPattern.test(rawText)) {\n  rawText = rawText.replace(ssnPattern, '[MASKED_PII_SSN]');\n  violations.push('SSN leak scrubbed');\n}\n\nreturn {\n  action: isViolated ? 'Blocked' : 'Proceed',\n  scrubbed_payload: rawText,\n  violations_detected: violations\n};"
      },
      "id": "node-security-scrub",
      "name": "Security Scrubber",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        350,
        100
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO n8n_core.runs (workflow_id, tenant_id, status, input_payload) VALUES ('flow-master-consolidated', 'tenant-default-01', 'In_Progress', '{\"test\": true}') RETURNING run_id;"
      },

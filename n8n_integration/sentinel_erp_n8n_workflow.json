      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"status\": \"Success\",\n  \"data\": {{ JSON.stringify($json) }}\n}",
        "options": {}
      },
      "id": "node-respond-chat",
      "name": "Respond Success Chat",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        1850,
        100
      ]
    },
    {
      "parameters": {
        "jsCode": "const text = item.json.body.document_text || '';\nconst words = text.split(/\\s+/);\nconst chunks = [];\nconst chunkSize = 200;\nconst overlap = 40;\nfor (let i = 0; i < words.length; i += (chunkSize - overlap)) {\n  chunks.push({ \n    json: { \n      chunk_content: words.slice(i, i + chunkSize).join(' '),\n      doc_title: item.json.body.doc_title || 'Untitled'\n    } \n  });\n  if (i + chunkSize >= words.length) break;\n}\nreturn chunks;"
      },
      "id": "node-rag-splitter",
      "name": "RAG Text Splitter",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        350,
        900
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/text-embedding-004:embedContent",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "models/text-embedding-004"
            },
            {
              "name": "content.parts[0].text",
              "value": "={{ $json.chunk_content }}"
            }
          ]
        },
        "options": {}
      },
      "id": "node-rag-embeddings",
      "name": "RAG Generate Embeddings",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        550,
        900
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "cred-gemini-header-api-key",
          "name": "Gemini API Header Auth"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=INSERT INTO vector_store.embeddings (doc_title, chunk_content, embedding) VALUES ('{{ $('RAG Text Splitter').item.json.doc_title }}', '{{ $('RAG Text Splitter').item.json.chunk_content }}', '{{ JSON.stringify($json.embedding.values) }}'::vector) RETURNING embedding_id;"
      },
      "id": "node-rag-save-db",
      "name": "Save Embeddings SQL",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [
        750,
        900
      ],
      "credentials": {
        "postgres": {
          "id": "cred-postgres-db",
          "name": "Sentinel ERP DB Connection"
        }
      }
